#!/bin/busybox sh
set -eu

export PATH=/bin:/usr/bin:/usr/sbin
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /run
mount -t tmpfs tmpfs /tmp
mkdir -p /dev/pts /run/user/0 /var/log /var/lib /etc/xdg/weston
mkdir -p /run/udev
mount -t devpts devpts /dev/pts || true

hostname qemu-lab-phase3
echo 8 > /proc/sys/kernel/printk || true
echo "[init-phase3] booted" >/dev/console

ip link set lo up
ip link set eth0 up || true
ip addr add 10.0.2.15/24 dev eth0 2>/dev/null || true
ip route add default via 10.0.2.2 dev eth0 2>/dev/null || true

chmod 0700 /run/user/0
export XDG_RUNTIME_DIR=/run/user/0
export WAYLAND_DISPLAY=wayland-1
export HOME=/root
export WESTON_CONFIG_FILE=/etc/xdg/weston/weston.ini
export LIBSEAT_BACKEND=seatd
export LD_LIBRARY_PATH=/usr/lib/chromium-browser:/usr/lib/x86_64-linux-gnu/weston:/usr/lib/x86_64-linux-gnu:/lib/x86_64-linux-gnu:/lib64
export FONTCONFIG_PATH=/etc/fonts

DISPLAY_PROBE=0
UNBIND_FBCON=0
URL=about:blank
CLIENT=chromium
RUNTIME_SECONDS=
SUSPEND_DELAY_SECONDS=
WAKE_SECONDS=
PM_TEST=
NO_SUSPEND=

KERNEL_RELEASE=$(uname -r)
for module in \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/virtio/virtio_dma_buf.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/gpu/drm/virtio/virtio-gpu.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/hid.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/hid-generic.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbhid.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbkbd.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbmouse.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/input/mouse/psmouse.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/usb/host/xhci-pci-renesas.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/usb/host/xhci-pci.ko"
do
  if [ -f "$module" ]; then
    echo "[init-phase3] loading module=$module" >/dev/console
    insmod "$module" >/dev/console 2>&1 || true
  fi
done

/lib/systemd/systemd-udevd --daemon >/dev/console 2>&1 || true
udevadm trigger --action=add --subsystem-match=input >/dev/console 2>&1 || true
udevadm trigger --action=add --subsystem-match=drm >/dev/console 2>&1 || true
udevadm settle >/dev/console 2>&1 || true

ls -l /dev/dri >/dev/console 2>&1 || echo "[init-phase3] /dev/dri missing" >/dev/console
ls -l /dev/input >/dev/console 2>&1 || echo "[init-phase3] /dev/input missing" >/dev/console

/usr/sbin/seatd >/var/log/seatd.log 2>&1 &
SEATD_PID=$!
echo "[init-phase3] seatd pid=$SEATD_PID" >/dev/console

/usr/bin/weston \
  --backend=drm \
  --renderer=pixman \
  --shell=kiosk-shell.so \
  --socket="$WAYLAND_DISPLAY" \
  --continue-without-input \
  --log=/var/log/weston.log >/dev/console 2>&1 &
WESTON_PID=$!
echo "[init-phase3] weston pid=$WESTON_PID" >/dev/console

tries=0
while [ ! -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ] && [ $tries -lt 100 ]; do
  tries=$((tries + 1))
  sleep 0.1
done

if [ ! -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]; then
  echo "[init-phase3] wayland socket did not appear" >/dev/console
  sed -n '1,200p' /var/log/weston.log >/dev/console 2>&1 || true
  poweroff -f
fi

for arg in $(cat /proc/cmdline); do
  case "$arg" in
    display_probe=1) DISPLAY_PROBE=1 ;;
    display_unbind_fbcon=1) UNBIND_FBCON=1 ;;
    phase3_client=*) CLIENT=${arg#phase3_client=} ;;
    phase3_url=*) URL=${arg#phase3_url=} ;;
    phase3_runtime_seconds=*) RUNTIME_SECONDS=${arg#phase3_runtime_seconds=} ;;
    phase3_suspend_delay_seconds=*) SUSPEND_DELAY_SECONDS=${arg#phase3_suspend_delay_seconds=} ;;
    phase3_wake_seconds=*) WAKE_SECONDS=${arg#phase3_wake_seconds=} ;;
    phase3_pm_test=*) PM_TEST=${arg#phase3_pm_test=} ;;
    phase3_no_suspend=1) NO_SUSPEND=1 ;;
  esac
done

echo "[init-phase3] wayland ready" >/dev/console
sed -n '1,160p' /var/log/weston.log >/dev/console 2>&1 || true

if [ "$UNBIND_FBCON" = "1" ]; then
  for vtcon in /sys/class/vtconsole/vtcon*; do
    [ -r "$vtcon/name" ] || continue
    name=$(cat "$vtcon/name" 2>/dev/null || true)
    case "$name" in
      *frame\ buffer*)
        if [ -w "$vtcon/bind" ]; then
          echo 0 >"$vtcon/bind" 2>/dev/null || true
          echo "[init-phase3] unbound $(basename "$vtcon") framebuffer console" >/dev/console
        fi
        ;;
    esac
  done
fi

if [ "$DISPLAY_PROBE" = "1" ] && [ -x /usr/bin/display_probe.sh ]; then
  /usr/bin/display_probe.sh 1 /var/log/display_probe.log &
  DISPLAY_PROBE_PID=$!
  echo "[init-phase3] display_probe pid=$DISPLAY_PROBE_PID" >/dev/console
else
  DISPLAY_PROBE_PID=
fi

echo "[init-phase3] launching client=$CLIENT url=$URL runtime=$RUNTIME_SECONDS suspend_delay=$SUSPEND_DELAY_SECONDS wake=$WAKE_SECONDS pm_test=$PM_TEST no_suspend=$NO_SUSPEND" >/dev/console

APP_LOG=
case "$CLIENT" in
  chromium)
    APP_LOG=/var/log/chromium.log
    /usr/bin/chromium-wayland-launcher "$URL" >"$APP_LOG" 2>&1 &
    ;;
  weston-simple-shm)
    APP_LOG=/var/log/weston-simple-shm.log
    /usr/bin/weston-simple-shm >"$APP_LOG" 2>&1 &
    ;;
  *)
    echo "[init-phase3] unknown phase3_client=$CLIENT" >/dev/console
    poweroff -f
    ;;
esac
APP_PID=$!
echo "[init-phase3] app pid=$APP_PID client=$CLIENT" >/dev/console
[ -n "$APP_LOG" ] && tail -f "$APP_LOG" >/dev/console 2>&1 &

if [ -n "${SUSPEND_DELAY_SECONDS:-}" ]; then
  SUSPEND_ARGS="--delay-seconds $SUSPEND_DELAY_SECONDS"
  [ -n "${WAKE_SECONDS:-}" ] && SUSPEND_ARGS="$SUSPEND_ARGS --wake-seconds $WAKE_SECONDS"
  [ -n "${PM_TEST:-}" ] && SUSPEND_ARGS="$SUSPEND_ARGS --pm-test $PM_TEST"
  [ -n "${NO_SUSPEND:-}" ] && SUSPEND_ARGS="$SUSPEND_ARGS --no-suspend"
  echo "[init-phase3] scheduling suspend args=$SUSPEND_ARGS" >/dev/console
  /usr/bin/suspendctl $SUSPEND_ARGS >/dev/console 2>&1 &
  SUSPEND_PID=$!
else
  SUSPEND_PID=
fi

if [ -n "$RUNTIME_SECONDS" ]; then
  (
    sleep "$RUNTIME_SECONDS"
    echo "[init-phase3] runtime limit reached, terminating client=$CLIENT" >/dev/console
    kill "$APP_PID" 2>/dev/null || true
  ) &
fi

wait "$APP_PID" || true
[ -n "${SUSPEND_PID:-}" ] && wait "$SUSPEND_PID" || true
[ -n "${DISPLAY_PROBE_PID:-}" ] && kill "$DISPLAY_PROBE_PID" 2>/dev/null || true
[ -f /var/log/display_probe.log ] && tail -n 120 /var/log/display_probe.log >/dev/console 2>&1 || true
echo "[init-phase3] client exited client=$CLIENT" >/dev/console
poweroff -f
