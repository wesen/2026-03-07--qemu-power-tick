#!/bin/busybox sh
set -eu

export PATH=/bin:/usr/bin:/usr/sbin
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /run
mount -t tmpfs tmpfs /tmp
mkdir -p /dev/pts /run/user/0 /var/log /var/lib /etc/xdg/weston
mkdir -p /run/udev
mount -t devpts devpts /dev/pts || true

hostname qemu-lab-phase2
echo 8 > /proc/sys/kernel/printk || true
echo "[init-phase2] booted" >/dev/console

ip link set lo up
ip link set eth0 up || true
ip addr add 10.0.2.15/24 dev eth0 2>/dev/null || true
ip route add default via 10.0.2.2 dev eth0 2>/dev/null || true

chmod 0700 /run/user/0
export XDG_RUNTIME_DIR=/run/user/0
export WAYLAND_DISPLAY=wayland-1
export HOME=/root
export WESTON_CONFIG_FILE=/etc/xdg/weston/weston.ini
export LIBSEAT_BACKEND=seatd
export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/weston:/usr/lib/x86_64-linux-gnu:/lib/x86_64-linux-gnu:/lib64

KERNEL_RELEASE=$(uname -r)
for module in \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/virtio/virtio_dma_buf.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/gpu/drm/virtio/virtio-gpu.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/hid.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/hid-generic.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbhid.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbkbd.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/hid/usbhid/usbmouse.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/input/mouse/psmouse.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/usb/host/xhci-pci-renesas.ko" \
  "/lib/modules/$KERNEL_RELEASE/kernel/drivers/usb/host/xhci-pci.ko"
do
  if [ -f "$module" ]; then
    echo "[init-phase2] loading module=$module" >/dev/console
    insmod "$module" >/dev/console 2>&1 || true
  fi
done

/lib/systemd/systemd-udevd --daemon >/dev/console 2>&1 || true
udevadm trigger --action=add --subsystem-match=input >/dev/console 2>&1 || true
udevadm trigger --action=add --subsystem-match=drm >/dev/console 2>&1 || true
udevadm settle >/dev/console 2>&1 || true

ls -l /dev/dri >/dev/console 2>&1 || echo "[init-phase2] /dev/dri missing" >/dev/console
ls -l /dev/input >/dev/console 2>&1 || echo "[init-phase2] /dev/input missing" >/dev/console

if [ -x /bin/evdev_probe ]; then
  /bin/evdev_probe >/var/log/evdev-probe.log 2>&1 &
  EVDEV_PROBE_PID=$!
  echo "[init-phase2] evdev_probe pid=$EVDEV_PROBE_PID" >/dev/console
  tail -f /var/log/evdev-probe.log >/dev/console 2>&1 &
fi

/usr/sbin/seatd >/var/log/seatd.log 2>&1 &
SEATD_PID=$!
echo "[init-phase2] seatd pid=$SEATD_PID" >/dev/console

/usr/bin/weston \
  --backend=drm \
  --renderer=pixman \
  --shell=kiosk-shell.so \
  --socket="$WAYLAND_DISPLAY" \
  --continue-without-input \
  --log=/var/log/weston.log >/dev/console 2>&1 &
WESTON_PID=$!
echo "[init-phase2] weston pid=$WESTON_PID" >/dev/console

tries=0
while [ ! -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ] && [ $tries -lt 100 ]; do
  tries=$((tries + 1))
  sleep 0.1
done

if [ ! -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]; then
  echo "[init-phase2] wayland socket did not appear" >/dev/console
  sed -n '1,200p' /var/log/weston.log >/dev/console 2>&1 || true
  poweroff -f
fi

echo "[init-phase2] wayland ready" >/dev/console
sed -n '1,160p' /var/log/weston.log >/dev/console 2>&1 || true

build_client_args() {
  IDLE_SECONDS=
  MAX_SUSPEND_CYCLES=
  WAKE_SECONDS=
  PM_TEST=
  RUNTIME_SECONDS=
  NO_SUSPEND=

  for arg in $(cat /proc/cmdline); do
    case "$arg" in
      phase2_idle_seconds=*) IDLE_SECONDS=${arg#phase2_idle_seconds=} ;;
      phase2_max_suspend_cycles=*) MAX_SUSPEND_CYCLES=${arg#phase2_max_suspend_cycles=} ;;
      phase2_wake_seconds=*) WAKE_SECONDS=${arg#phase2_wake_seconds=} ;;
      phase2_pm_test=*) PM_TEST=${arg#phase2_pm_test=} ;;
      phase2_runtime_seconds=*) RUNTIME_SECONDS=${arg#phase2_runtime_seconds=} ;;
      phase2_no_suspend=1) NO_SUSPEND=1 ;;
    esac
  done

  CLIENT_ARGS=
  [ -n "$IDLE_SECONDS" ] && CLIENT_ARGS="$CLIENT_ARGS --idle-seconds $IDLE_SECONDS"
  [ -n "$MAX_SUSPEND_CYCLES" ] && CLIENT_ARGS="$CLIENT_ARGS --max-suspend-cycles $MAX_SUSPEND_CYCLES"
  [ -n "$WAKE_SECONDS" ] && CLIENT_ARGS="$CLIENT_ARGS --wake-seconds $WAKE_SECONDS"
  [ -n "$PM_TEST" ] && CLIENT_ARGS="$CLIENT_ARGS --pm-test $PM_TEST"
  [ -n "$RUNTIME_SECONDS" ] && CLIENT_ARGS="$CLIENT_ARGS --runtime-seconds $RUNTIME_SECONDS"
  [ -n "$NO_SUSPEND" ] && CLIENT_ARGS="$CLIENT_ARGS --no-suspend"

  echo "$CLIENT_ARGS"
}

CLIENT_BIN=${PHASE2_CLIENT_BIN:-/usr/bin/weston-simple-shm}
if [ -x /bin/wl_sleepdemo ]; then
  CLIENT_BIN=/bin/wl_sleepdemo
fi

CLIENT_ARGS=$(build_client_args)
echo "[init-phase2] launching client=$CLIENT_BIN args=$CLIENT_ARGS" >/dev/console
exec "$CLIENT_BIN" $CLIENT_ARGS
